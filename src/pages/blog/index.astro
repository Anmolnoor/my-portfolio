---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import BlogPostList from "@/components/blog/BlogPostList";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const blogPosts = posts.map((post) => ({
  cover: post.data.cover,
  date: post.data.date.toISOString(),
  readingMinutes: post.data.readingMinutes,
  slug: post.data.slug ?? post.id.replace(/\.mdx$/, ""),
  summary: post.data.excerpt ?? post.data.description ?? "",
  tags: post.data.tags,
  title: post.data.title,
}));
---

<Main
  title="Blog — Anmol Noor"
  description="Notes on shipping software — frontend, distributed systems, infra, and developer tooling."
>
  <BlogPostList posts={blogPosts} client:load />
</Main>
